{% extends 'base.html.twig' %}

{% block title %}Compra Confirmada{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm border-success">
                    <div class="card-body text-center py-5">
                        <div class="text-success mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-check-circle" viewBox="0 0 16 16">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z"/>
                            </svg>
                        </div>
                        <h1 class="display-6 text-success mb-3">¡Compra Realizada!</h1>
                        <p class="lead mb-4">Tu pedido ha sido procesado correctamente.</p>
                        
                        <div class="bg-light p-4 rounded mb-4">
                            <p><strong>Número de pedido:</strong> #{{ compra.id }}</p>
                            <p><strong>Fecha:</strong> {{ compra.fechaCompra|date('d/m/Y H:i') }}</p>
                            <p class="mb-0"><strong>Total:</strong> {{ compra.total|number_format(2, ',', '.') }} €</p>
                        </div>

                        <h5 class="mb-3">Productos comprados:</h5>
                        <ul class="list-group mb-4">
                            {% for item in compra.items %}
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                {{ item.producto.titulo }} (x{{ item.cantidad }})
                                <span class="badge bg-primary rounded-pill">{{ item.subtotal|number_format(2, ',', '.') }} €</span>
                            </li>
                            {% endfor %}
                        </ul>

                        <p class="text-muted">Los vendedores han sido notificados de tu compra.</p>

                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <a href="{{ path('app_home') }}" class="btn btn-primary">Seguir Comprando</a>
                            <a href="{{ path('app_compra_historial') }}" class="btn btn-outline-secondary">Ver Historial</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
