{% extends 'base.html.twig' %}

{% block title %}Historial de Compras{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container">
        <h1 class="mb-4">Historial de Compras</h1>

        {% if compras is empty %}
            <div class="alert alert-info">
                No has realizado ninguna compra todavía. <a href="{{ path('app_home') }}">Ver productos</a>
            </div>
        {% else %}
            {% for compra in compras %}
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><strong>Pedido #{{ compra.id }}</strong> - {{ compra.fechaCompra|date('d/m/Y H:i') }}</span>
                    <span class="badge bg-success">{{ compra.estado }}</span>
                </div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Cantidad</th>
                                <th>Precio</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in compra.items %}
                            <tr>
                                <td>{{ item.producto.titulo }}</td>
                                <td>{{ item.cantidad }}</td>
                                <td>{{ item.precioUnitario|number_format(2, ',', '.') }} €</td>
                                <td>{{ item.subtotal|number_format(2, ',', '.') }} €</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end"><strong>Total:</strong></td>
                                <td><strong>{{ compra.total|number_format(2, ',', '.') }} €</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            {% endfor %}
        {% endif %}
    </div>
</section>
{% endblock %}
