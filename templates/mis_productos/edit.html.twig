{% extends 'base.html.twig' %}

{% block title %}Editar Producto
{% endblock %}

{% block body %}
	<section class="py-5">
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-md-8">
					<div class="card shadow-sm">
						<div class="card-header bg-warning">
							<h4 class="mb-0">Editar Producto</h4>
						</div>
						<div class="card-body">
							{% for message in app.flashes('success') %}
								<div class="alert alert-success alert-dismissible fade show">
									{{ message }}
									<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
								</div>
							{% endfor %}
							{% for message in app.flashes('error') %}
								<div class="alert alert-danger alert-dismissible fade show">
									{{ message }}
									<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
								</div>
							{% endfor %}

							{# Resumen detallado de errores de validación #}
							{% if form.vars.submitted and not form.vars.valid %}
								<div class="alert alert-danger" role="alert">
									<h5 class="alert-heading">
										<i class="bi bi-exclamation-triangle-fill me-2"></i>Por favor, revisa los siguientes errores:</h5>
									<hr>
									<ul
										class="mb-0">
										{# Errores globales del formulario #}
										{% for error in form.vars.errors %}
											<li>{{ error.message }}</li>
										{% endfor %}
										{# Errores de cada campo #}
										{% for child in form.children %}
											{% for error in child.vars.errors %}
												<li>
													<strong>{{ child.vars.label|default(child.vars.name|capitalize) }}:</strong>
													{{ error.message }}</li>
											{% endfor %}
										{% endfor %}
									</ul>
								</div>
							{% endif %}

							{% if producto.imagen %}
								<div class="text-center mb-4">
									<img src="{{ asset('images/' ~ producto.imagen) }}" alt="{{ producto.titulo }}" class="img-thumbnail" style="max-height: 200px;">
									<p class="text-muted small mt-2">Imagen actual</p>
								</div>
							{% endif %}

							{{ form_start(form, {'attr': {'class': 'needs-validation', 'enctype': 'multipart/form-data', 'novalidate': 'novalidate'}}) }}

							<div class="mb-3">
								{{ form_label(form.titulo) }}
								{{ form_widget(form.titulo) }}
								{{ form_errors(form.titulo) }}
							</div>

							<div class="mb-3">
								{{ form_label(form.descripcion) }}
								{{ form_widget(form.descripcion) }}
								{{ form_errors(form.descripcion) }}
							</div>

							<div class="row">
								<div class="col-md-6 mb-3">
									{{ form_label(form.precio) }}
									{{ form_widget(form.precio) }}
									{{ form_errors(form.precio) }}
								</div>
								<div class="col-md-6 mb-3">
									{{ form_label(form.categoria) }}
									{{ form_widget(form.categoria) }}
									{{ form_errors(form.categoria) }}
								</div>
							</div>

							<div class="row">
								<div class="col-md-6 mb-3">
									{{ form_label(form.fechaInicial) }}
									{{ form_widget(form.fechaInicial) }}
									{{ form_errors(form.fechaInicial) }}
								</div>
								<div class="col-md-6 mb-3">
									{{ form_label(form.fechaFinal) }}
									{{ form_widget(form.fechaFinal) }}
									{{ form_errors(form.fechaFinal) }}
								</div>
							</div>

							<div class="mb-3">
								{{ form_label(form.imagenFile) }}
								{{ form_widget(form.imagenFile) }}
								{{ form_errors(form.imagenFile) }}
								<small class="text-muted">Deja vacío para mantener la imagen actual.</small>
							</div>

							<div class="d-flex justify-content-between mt-4">
								<a href="{{ path('app_mis_productos') }}" class="btn btn-outline-secondary">Cancelar</a>
								<button type="submit" class="btn btn-warning">Guardar Cambios</button>
							</div>

							{{ form_end(form) }}
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
{% endblock %}
