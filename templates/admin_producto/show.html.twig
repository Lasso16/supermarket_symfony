{% extends 'base.html.twig' %}

{% block title %}Producto{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Producto</h1>

        <table class="table">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ producto.id }}</td>
                </tr>
                <tr>
                    <th>Titulo</th>
                    <td>{{ producto.titulo }}</td>
                </tr>
                <tr>
                    <th>Descripcion</th>
                    <td>{{ producto.descripcion }}</td>
                </tr>
                <tr>
                    <th>Precio</th>
                    <td>{{ producto.precio }}</td>
                </tr>
                <tr>
                    <th>Imagen</th>
                    <td>{{ producto.imagen }}</td>
                </tr>
                <tr>
                    <th>FechaCreacion</th>
                    <td>{{ producto.fechaCreacion ? producto.fechaCreacion|date('Y-m-d H:i:s') : '' }}</td>
                </tr>
            </tbody>
        </table>

        <a href="{{ path('app_admin_producto_index') }}">back to list</a>
        <a href="{{ path('app_admin_producto_edit', {'id': producto.id}) }}">edit</a>

        {{ include('admin_producto/_delete_form.html.twig') }}
    </div>
{% endblock %}
