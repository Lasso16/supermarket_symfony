{% extends 'base.html.twig' %}

{% block title %}{{ producto.titulo }} - Detalles{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container">
        <div class="row">
            <div class="col-md-6">
                    <img src="{{ asset(images_directory ~ producto.imagen) }}" alt="{{ producto.titulo }}" class="img-fluid rounded shadow">
            </div>
            <div class="col-md-6">
                <h1 class="display-4 mb-3">{{ producto.titulo }}</h1>
                
                <div class="mb-3">
                    <h4 class="text-primary">{{ producto.precio|number_format(2, ',', '.') }} €</h4>
                </div>

                <div class="mb-3">
                    <strong>Fecha de venta:</strong><br>
                    {% if producto.fechaInicial and producto.fechaFinal %}
                        Del {{ producto.fechaInicial|date('d/m/Y') }} al {{ producto.fechaFinal|date('d/m/Y') }}
                    {% elseif producto.fechaInicial %}
                        Desde {{ producto.fechaInicial|date('d/m/Y') }}
                    {% elseif producto.fechaFinal %}
                        Hasta {{ producto.fechaFinal|date('d/m/Y') }}
                    {% else %}
                        Sin fecha definida
                    {% endif %}
                </div>

                <div class="mb-3">
                    <strong>Publicado por:</strong>
                    <a href="{{ path('app_home', {'usuario': producto.usuario.id}) }}" class="text-decoration-none">
                        {{ producto.usuario.nombreUsuario }}
                    </a>
                </div>

                <div class="mb-4">
                    <h5>Descripción</h5>
                    <p class="text-muted">{{ producto.descripcion ?? 'Sin descripción disponible.' }}</p>
                </div>

                <div class="d-flex gap-2">
                    {% if app.user %}
                        <a href="{{ path('app_carrito_add', {'id': producto.id}) }}" class="btn btn-success">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cart-plus" viewBox="0 0 16 16">
                                <path d="M9 5.5a.5.5 0 0 0-1 0V7H6.5a.5.5 0 0 0 0 1H8v1.5a.5.5 0 0 0 1 0V8h1.5a.5.5 0 0 0 0-1H9V5.5z"/>
                                <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1H.5zm3.915 10L3.102 4h10.796l-1.313 7h-8.17zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                            </svg>
                            Añadir al carrito
                        </a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-success">
                            Inicia sesión para comprar
                        </a>
                    {% endif %}
                    <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">
                        Volver al listado
                    </a>
                    {% if app.user and (producto.usuario == app.user or is_granted('ROLE_ADMIN')) %}
                        <a href="{{ path('app_admin_producto_edit', {'id': producto.id}) }}" class="btn btn-warning">
                            Editar producto
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
