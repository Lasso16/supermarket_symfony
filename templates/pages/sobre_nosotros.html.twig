{# Values Section #}
<section class="py-5">
  <div class="container-lg">
    <div class="text-center mb-5">
      <span class="badge bg-primary text-uppercase px-3 py-2 mb-3">Nuestros Valores</span>
      <h2 class="display-5 fw-bold">Lo que nos define</h2>
    </div>
    <div class="row g-4">
      <div class="col-md-3">
        <div class="text-center">
          <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 mb-3" style="width: 80px; height: 80px;">
            <svg width="40" height="40" class="text-primary"><use xlink:href="#organic"></use></svg>
          </div>
          <h5 class="fw-bold">Sostenibilidad</h5>
          <p class="text-muted small">Cuidamos el planeta con prácticas eco-friendly en todo lo que hacemos.</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="text-center">
          <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10 mb-3" style="width: 80px; height: 80px;">
            <svg width="40" height="40" class="text-success"><use xlink:href="#quality"></use></svg>
          </div>
          <h5 class="fw-bold">Calidad</h5>
          <p class="text-muted small">Solo ofrecemos productos certificados de la más alta calidad.</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="text-center">
          <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10 mb-3" style="width: 80px; height: 80px;">
            <svg width="40" height="40" class="text-warning"><use xlink:href="#secure"></use></svg>
          </div>
          <h5 class="fw-bold">Transparencia</h5>
          <p class="text-muted small">Conoce el origen de cada producto que compras.</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="text-center">
          <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10 mb-3" style="width: 80px; height: 80px;">
            <svg width="40" height="40" class="text-danger"><use xlink:href="#fresh"></use></svg>
          </div>
          <h5 class="fw-bold">Frescura</h5>
          <p class="text-muted small">Productos siempre frescos, directos del campo.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{# CTA Section #}
<section class="py-5 bg-primary text-white">
  <div class="container-lg text-center">
    <h2 class="display-5 fw-bold mb-4">¿Listo para empezar a comer sano?</h2>
    <p class="lead mb-4">Únete a nuestra comunidad de más de 50,000 clientes satisfechos</p>
    <a href="{{ path('app_register') }}" class="btn btn-light btn-lg px-5 rounded-pill">¡Regístrate Ahora!</a>
  </div>
</section>

