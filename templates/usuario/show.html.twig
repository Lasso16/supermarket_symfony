{% extends 'base.html.twig' %}

{% block title %}Usuario{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Usuario</h1>

        <table class="table">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ usuario.id }}</td>
                </tr>
                <tr>
                    <th>NombreUsuario</th>
                    <td>{{ usuario.nombreUsuario }}</td>
                </tr>
                <tr>
                    <th>Email</th>
                    <td>{{ usuario.email }}</td>
                </tr>
                <tr>
                    <th>Password</th>
                    <td>{{ usuario.password }}</td>
                </tr>
                <tr>
                    <th>Tipo</th>
                    <td>{{ usuario.tipo }}</td>
                </tr>
                <tr>
                    <th>Avatar</th>
                    <td>{{ usuario.avatar }}</td>
                </tr>
                <tr>
                    <th>FechaRegistro</th>
                    <td>{{ usuario.fechaRegistro ? usuario.fechaRegistro|date('Y-m-d H:i:s') : '' }}</td>
                </tr>
            </tbody>
        </table>

        <a href="{{ path('app_usuario_index') }}">back to list</a>
        <a href="{{ path('app_usuario_edit', {'id': usuario.id}) }}">edit</a>

        {{ include('usuario/_delete_form.html.twig') }}
    </div>
{% endblock %}
