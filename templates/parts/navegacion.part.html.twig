{# Main Navigation Header #}
<header>
  <div class="container-fluid">
    <div class="row py-3 border-bottom">
      
      {# Logo and Menu Toggle #}
      <div class="col-sm-4 col-lg-2 text-center text-sm-start d-flex gap-3 justify-content-center justify-content-md-start">
        <div class="d-flex align-items-center my-3 my-sm-0">
          <a href="/">
            <img src="{{ asset('images/logo.svg') }}" alt="Organic" class="img-fluid">
          </a>
        </div>
        <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar">
          <svg width="24" height="24" viewBox="0 0 24 24"><use xlink:href="#menu"></use></svg>
        </button>
      </div>
      
      {# Top Navigation Menu #}
      <div class="col-lg-8">
        <ul class="navbar-nav list-unstyled d-flex flex-row gap-2 gap-lg-4 justify-content-center flex-wrap align-items-center mb-0 text-dark">
          <li class="nav-item">
            <a href="/" class="nav-link d-flex align-items-center gap-1">
              <svg width="16" height="16"><use xlink:href="#home"></use></svg>
              <span>Inicio</span>
            </a>
          </li>
          
          {% if not app.user %}
            <li class="nav-item">
              <a href="{{ path('app_sobre_nosotros') }}" class="nav-link d-flex align-items-center gap-1">
                <svg width="16" height="16"><use xlink:href="#user"></use></svg>
                <span>Sobre Nosotros</span>
              </a>
            </li>
            <li class="nav-item">
              <a href="{{ path('app_contacto') }}" class="nav-link d-flex align-items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-telephone" viewBox="0 0 16 16">
                  <path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328zM1.884.511a1.745 1.745 0 0 1 2.612.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511z"/>
                </svg>
                <span>Contacto</span>
              </a>
            </li>
            <li class="nav-item">
              <a href="{{ path('app_blog') }}" class="nav-link d-flex align-items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-book" viewBox="0 0 16 16">
                  <path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783z"/>
                </svg>
                <span>Blog</span>
              </a>
            </li>
          {% endif %}
          
          {% if app.user %}
            <li class="nav-item">
              <a href="{{ path('app_mis_productos') }}" class="nav-link d-flex align-items-center gap-1">
                <svg width="16" height="16"><use xlink:href="#package"></use></svg>
                <span>Mis Productos</span>
              </a>
            </li>
            <li class="nav-item">
              <a href="{{ path('app_compra_historial') }}" class="nav-link d-flex align-items-center gap-1">
                <svg width="16" height="16"><use xlink:href="#shopping-bag"></use></svg>
                <span>Mis Compras</span>
              </a>
            </li>
            <li class="nav-item">
              <a href="{{ path('app_carrito') }}" class="nav-link d-flex align-items-center gap-1">
                <svg width="16" height="16"><use xlink:href="#cart"></use></svg>
                <span>Carrito</span>
              </a>
            </li>
            
            {% if is_granted('ROLE_ADMIN') %}
              <li class="nav-item">
                <a href="{{ path('app_usuario_index') }}" class="nav-link d-flex align-items-center gap-1 text-danger">
                  <svg width="16" height="16"><use xlink:href="#user"></use></svg>
                  <span>Usuarios</span>
                </a>
              </li>
              <li class="nav-item">
                <a href="{{ path('app_admin_producto_index') }}" class="nav-link d-flex align-items-center gap-1 text-danger">
                  <svg width="16" height="16"><use xlink:href="#quality"></use></svg>
                  <span>Productos</span>
                </a>
              </li>
            {% endif %}
          {% endif %}
        </ul>
      </div>
      
      {# User Icons (User, Wishlist, Cart) #}
      <div class="col-sm-8 col-lg-2 d-flex gap-5 align-items-center justify-content-center justify-content-sm-end">
        <ul class="d-flex justify-content-end list-unstyled m-0">
          {% if app.user %}
          <li>
            <a href="{{ path('app_perfil') }}" class="p-2 mx-1" title="Mi perfil">
              <img src="{{ asset('images/' ~ (app.user.avatar ?? 'default_avatar.png')) }}" 
                   alt="{{ app.user.nombreUsuario }}" 
                   class="rounded-circle" 
                   style="width: 32px; height: 32px; object-fit: cover;">
            </a>
          </li>
          <li>
            <a href="{{ path('app_logout') }}" class="p-2 mx-1 text-dark" title="Cerrar sesión">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z"/>
                <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z"/>
              </svg>
            </a>
          </li>
          {% else %}
          <li>
            <a href="{{ path('app_login') }}" class="p-2 mx-1" title="Iniciar sesión">
              <svg width="24" height="24"><use xlink:href="#user"></use></svg>
            </a>
          </li>
          <li>
            <a href="{{ path('app_register') }}" class="p-2 mx-1" title="Registrarse">
              <svg width="24" height="24"><use xlink:href="#fresh"></use></svg>
            </a>
          </li>
          {% endif %}
          <li>
            <a href="{{ path('app_carrito') }}" class="p-2 mx-1" title="Carrito">
              <svg width="24" height="24"><use xlink:href="#shopping-bag"></use></svg>
            </a>
          </li>
        </ul>
      </div>

    </div>
  </div>
</header>
