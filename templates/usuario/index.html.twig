{% extends 'base.html.twig' %}

{% block title %}Gestión de Usuarios{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container">
        <h1 class="mb-4">Gestión de Usuarios</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {# Filter by type #}
        <form method="get" class="mb-4">
            <div class="row g-3">
                <div class="col-auto">
                    <select name="tipo" class="form-select">
                        <option value="">Todos los usuarios</option>
                        <option value="normal" {{ tipoFilter == 'normal' ? 'selected' : '' }}>Normal</option>
                        <option value="admin" {{ tipoFilter == 'admin' ? 'selected' : '' }}>Admin</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">Filtrar</button>
                    {% if tipoFilter %}
                        <a href="{{ path('app_usuario_index') }}" class="btn btn-outline-secondary">Limpiar</a>
                    {% endif %}
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Avatar</th>
                        <th>Usuario</th>
                        <th>Email</th>
                        <th>Tipo</th>
                        <th>Fecha Registro</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for usuario in usuarios %}
                    <tr>
                        <td>{{ usuario.id }}</td>
                        <td>
                            <img src="{{ asset('images/' ~ (usuario.avatar ?? 'default_avatar.png')) }}" 
                                 alt="{{ usuario.nombreUsuario }}" 
                                 class="rounded-circle" 
                                 style="width: 40px; height: 40px; object-fit: cover;">
                        </td>
                        <td>{{ usuario.nombreUsuario }}</td>
                        <td>{{ usuario.email }}</td>
                        <td>
                            {% set isAdmin = 'ROLE_ADMIN' in usuario.roles %}
                            <span class="badge {{ isAdmin ? 'bg-danger' : 'bg-secondary' }}">
                                {{ isAdmin ? 'ADMIN' : 'USER' }}
                            </span>
                        </td>
                        <td>{{ usuario.fechaRegistro ? usuario.fechaRegistro|date('d/m/Y') : '-' }}</td>
                        <td>
                            <div class="d-flex gap-2">
                                {# Change Role #}
                                <form action="{{ path('app_usuario_cambiar_rol', {'id': usuario.id}) }}" method="post" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cambiar-rol' ~ usuario.id) }}">
                                    <div class="d-flex gap-1">
                                        <select name="nuevo_rol" class="form-select form-select-sm" style="width: auto;">
                                            {% set isAdmin = 'ROLE_ADMIN' in usuario.roles %}
                                            <option value="ROLE_USER" {{ not isAdmin ? 'selected' : '' }}>User</option>
                                            <option value="ROLE_ADMIN" {{ isAdmin ? 'selected' : '' }}>Admin</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-primary" title="Cambiar rol">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                                            </svg>
                                        </button>
                                    </div>
                                </form>
                                
                                {# Delete #}
                                {% if usuario != app.user %}
                                <form action="{{ path('app_usuario_delete', {'id': usuario.id}) }}" method="post" class="d-inline" onsubmit="return confirm('¿Estás seguro de que quieres eliminar este usuario?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ usuario.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                                            <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                                        </svg>
                                    </button>
                                </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted">No hay usuarios.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>
{% endblock %}
