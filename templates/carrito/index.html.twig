{% extends 'base.html.twig' %}

{% block title %}Carrito de Compras{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container">
        <h1 class="mb-4">Carrito de Compras</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        {% if items is empty %}
            <div class="alert alert-info">
                Tu carrito está vacío. <a href="{{ path('app_home') }}">Ver productos</a>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Precio</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in items %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="{{ asset('images/gallery/' ~ item.producto.imagen) }}" alt="{{ item.producto.titulo }}" style="width: 50px; height: 50px; object-fit: cover;" class="me-2 rounded">
                                    {{ item.producto.titulo }}
                                </div>
                            </td>
                            <td>{{ item.producto.precio|number_format(2, ',', '.') }} €</td>
                            <td>{{ item.cantidad }}</td>
                            <td>{{ item.subtotal|number_format(2, ',', '.') }} €</td>
                            <td>
                                <a href="{{ path('app_carrito_remove', {'id': item.producto.id}) }}" class="btn btn-sm btn-outline-danger">
                                    Eliminar
                                </a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end"><strong>Total:</strong></td>
                            <td colspan="2"><strong>{{ total|number_format(2, ',', '.') }} €</strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a href="{{ path('app_carrito_clear') }}" class="btn btn-outline-secondary">Vaciar Carrito</a>
                <a href="{{ path('app_compra_checkout') }}" class="btn btn-success btn-lg">Finalizar Compra</a>
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
