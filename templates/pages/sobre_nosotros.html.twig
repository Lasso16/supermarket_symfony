{% extends 'base.html.twig' %}

{% block title %}Sobre Nosotros - Organic{% endblock %}

{% block body %}

{# Hero Section #}
<section class="py-5" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9f5e9 100%);">
  <div class="container-lg">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <span class="badge bg-primary text-uppercase px-3 py-2 mb-3">Nuestra Historia</span>
        <h1 class="display-4 fw-bold mb-4">Somos <span class="text-primary">Organic</span></h1>
        <p class="lead text-muted mb-4">
          Desde 2015, nos dedicamos a llevar productos orgánicos de la más alta calidad directamente desde el campo hasta tu hogar. 
          Creemos en una alimentación sana, sostenible y respetuosa con el medio ambiente.
        </p>
        <div class="d-flex gap-4 mb-4">
          <div class="text-center">
            <h3 class="text-primary fw-bold mb-0">10+</h3>
            <small class="text-muted">Años de experiencia</small>
          </div>
          <div class="text-center">
            <h3 class="text-primary fw-bold mb-0">50K+</h3>
            <small class="text-muted">Clientes satisfechos</small>
          </div>
          <div class="text-center">
            <h3 class="text-primary fw-bold mb-0">100%</h3>
            <small class="text-muted">Productos orgánicos</small>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <img src="{{ asset('images/banner-1.jpg') }}" alt="Sobre Nosotros" class="img-fluid rounded-4 shadow-lg">
      </div>
    </div>
  </div>
</section>

{# Mission & Vision #}
<section class="py-5">
  <div class="container-lg">
    <div class="row g-4">
      <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm p-4" style="background: linear-gradient(135deg, #8bc34a 0%, #689f38 100%);">
          <div class="card-body text-white">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white bg-opacity-25 mb-3" style="width: 60px; height: 60px;">
              <svg width="30" height="30" fill="white"><use xlink:href="#organic"></use></svg>
            </div>
            <h3 class="fw-bold text-white">Nuestra Misión</h3>
            <p class="mb-0 opacity-75">
              Promover un estilo de vida saludable ofreciendo productos 100% orgánicos y naturales, 
              apoyando a los agricultores locales y cuidando el planeta para las futuras generaciones.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm p-4" style="background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);">
          <div class="card-body text-white">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white bg-opacity-25 mb-3" style="width: 60px; height: 60px;">
              <svg width="30" height="30" fill="white"><use xlink:href="#fresh"></use></svg>
            </div>
            <h3 class="fw-bold text-white">Nuestra Visión</h3>
            <p class="mb-0 opacity-75">
              Ser la plataforma líder en España para la compra de productos orgánicos, 
              conectando directamente a productores con consumidores conscientes de su alimentación.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

