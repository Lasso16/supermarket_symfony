{# Shopping Cart Offcanvas - Sidebar that shows cart items #}
<div class="offcanvas offcanvas-end" data-bs-scroll="true" tabindex="-1" id="offcanvasCart">
  <div class="offcanvas-header justify-content-center">
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body">
    <div class="order-md-last">
      <h4 class="d-flex justify-content-between align-items-center mb-3">
        <span class="text-primary">Tu Carrito</span>
        <span class="badge bg-primary rounded-pill">3</span>
      </h4>
      <ul class="list-group mb-3">
        <li class="list-group-item d-flex justify-content-between lh-sm">
          <div>
            <h6 class="my-0">Cidra Ecológica</h6>
            <small class="text-body-secondary">Bebida orgánica</small>
          </div>
          <span class="text-body-secondary">€12</span>
        </li>
        <li class="list-group-item d-flex justify-content-between lh-sm">
          <div>
            <h6 class="my-0">Uvas Frescas</h6>
            <small class="text-body-secondary">Producto fresco</small>
          </div>
          <span class="text-body-secondary">€8</span>
        </li>
        <li class="list-group-item d-flex justify-content-between lh-sm">
          <div>
            <h6 class="my-0">Ketchup Orgánico</h6>
            <small class="text-body-secondary">Conserva</small>
          </div>
          <span class="text-body-secondary">€5</span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
          <span>Total (EUR)</span>
          <strong>€25</strong>
        </li>
      </ul>

      <button class="w-100 btn btn-primary btn-lg" type="submit">Continuar al pago</button>
    </div>
  </div>
</div>
